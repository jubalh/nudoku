#: src/main.c:107
#, c-format
msgid ""
"nudoku [option]\n"
"\n"
msgstr ""
"nudoku [オプション]\n"
"\n"

#: src/main.c:108
#, c-format
msgid "Options:\n"
msgstr "オプション:\n"

#: src/main.c:109
#, c-format
msgid "-h help:\t\tPrint this help\n"
msgstr "-h:\t\tこの手引きを表示\n"

#: src/main.c:110
#, c-format
msgid "-v version:\t\tPrint version\n"
msgstr "-v:\t\t版を表示\n"

#: src/main.c:111
#, c-format
msgid "-c nocolor:\t\tDo not use colors\n"
msgstr "-c:\t\t着色しない\n"

#: src/main.c:112
#, c-format
msgid "-o output:\t\tOutput stream (inverse of -s)\n"
msgstr ""

#: src/main.c:113
#, c-format
msgid "-d difficulty:\t\tChoose between: easy, normal, hard\n"
msgstr "-d 難易度:\t\t難易度を選択: easy, normal, hard\n"

#: src/main.c:114
#, c-format
msgid "-s stream:\t\tUser provided sudoku stream\n"
msgstr "-s 版面:\t\t数独の盤面を指定する\n"

#: src/main.c:115
#, c-format
msgid "-r resume:\t\tResume the last saved game\n"
msgstr ""

#: src/main.c:116
#, c-format
msgid "-p filename:\t\tOutput PDF\n"
msgstr ""

#: src/main.c:117
#, c-format
msgid "-n filename:\t\tNumber of sudokus to put in PDF\n"
msgstr ""

#: src/main.c:118
#, c-format
msgid "-i filename:\t\tOutput PNG image\n"
msgstr ""

#: src/main.c:119
#, c-format
msgid ""
"-S papername:\t\tPDF paper size (e.g., 'a4', 'letter', 'legal'; default "
"'a4') or 'WIDTHxHEIGHT[unit]'\n"
msgstr ""

#: src/main.c:133
#, c-format
msgid "Character %c at position %d is not allowed.\n"
msgstr "文字%cは位置%dにあってはなりません。\n"

#: src/main.c:141
#, c-format
msgid "Stream has to be %d characters long.\n"
msgstr "版面は%d文字以上なくてはなりません。\n"

#: src/main.c:147
#, c-format
msgid "Stream does not represent a valid sudoku puzzle.\n"
msgstr "指定された版面は妥当な数独の問題を表わせません。\n"

#: src/main.c:318
#, c-format
msgid "Game save is missing or corrupted, try starting new game.\n"
msgstr ""

#: src/main.c:396
msgid ""
"Your terminal doesn't support colors.\n"
"Try the nocolor (-c) option.\n"
msgstr ""
"お使いの端末は着色に対応していません。\n"
"無着色 (-c) オプションをお試しください。\n"

#: src/main.c:487
#, c-format
msgid ""
"level: %s\n"
"\n"
msgstr ""
"難易度: %s\n"
"\n"

#: src/main.c:496
msgid "Movement\n"
msgstr "移  動\n"

#: src/main.c:497
msgid " h - Move left\n"
msgstr " h - 左に移動\n"

#: src/main.c:498
msgid " j - Move down\n"
msgstr " j - 下に移動\n"

#: src/main.c:499
msgid " k - Move up\n"
msgstr " k - 上に移動\n"

#: src/main.c:500
msgid ""
" l - Move right\n"
"\n"
msgstr ""
" l - 右に移動\n"
"\n"

#: src/main.c:501
msgid "Commands\n"
msgstr "命  令\n"

#: src/main.c:502
msgid " c - Check solution\n"
msgstr " c - 解答を確かめる\n"

#: src/main.c:503
msgid " H - Give a hint\n"
msgstr " H - 手掛かりを見る\n"

#: src/main.c:506
msgid " m - Toggle marks\n"
msgstr " m - 印を付ける/外す\n"

#: src/main.c:508
msgid " N - New puzzle\n"
msgstr " N - 新しい問題\n"

#: src/main.c:509
msgid " G - Save\n"
msgstr ""

#: src/main.c:510
msgid " Q - Quit\n"
msgstr " Q - 終了\n"

#: src/main.c:511
msgid " r - Redraw\n"
msgstr " r - 再描画\n"

#: src/main.c:512
msgid " S - Solve puzzle\n"
msgstr " S - 問題を解く\n"

#: src/main.c:513
msgid " x - Delete number\n"
msgstr " x - 数字を消す\n"

#: src/main.c:514
msgid " u - Undo previous action\n"
msgstr ""

#: src/main.c:678
#, c-format
msgid "nudoku is compiled without cairo support.\n"
msgstr ""

#: src/main.c:679
#, c-format
msgid "To use the output feature, please compile with --enable-cairo.\n"
msgstr ""

#: src/main.c:799
msgid "Solving puzzle..."
msgstr "問題を解いています..."

#: src/main.c:805 src/main.c:847
msgid "Solved"
msgstr "正解です"

#: src/main.c:815
msgid "Generating puzzle..."
msgstr "問題を生成しています..."

#: src/main.c:841
msgid "Not correct"
msgstr "不正解です"

#: src/main.c:852
#, c-format
msgid " with the help of %d hints"
msgstr "（手掛かりを%d回見ました）"

#: src/main.c:860
msgid "Correct so far"
msgstr "現時点では正解です"

#: src/main.c:890
msgid "Provided hint"
msgstr "手掛りを得ました"

#: src/main.c:903
msgid "Saved!"
msgstr ""

#: src/main.c:906
msgid "Can't save the game!"
msgstr ""

#: src/sudoku.c:279
msgid "hard"
msgstr "難"

#: src/sudoku.c:281
msgid "normal"
msgstr "中"

#: src/sudoku.c:284
msgid "easy"
msgstr "易"

#: src/outp.c:172
#, c-format
msgid "ERROR: Page dimensions are too small for sudokus to fit!\n"
msgstr ""

#: src/outp.c:173
#, c-format
msgid "Please check the dimensions provided in '-S' and try again.\n"
msgstr ""
